<Window x:Class="VsAgentic.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:VsAgentic.UI;assembly=VsAgentic.UI"
        xmlns:vm="clr-namespace:VsAgentic.UI.ViewModels;assembly=VsAgentic.UI"
        xmlns:conv="clr-namespace:VsAgentic.UI.Converters;assembly=VsAgentic.UI"
        xmlns:controls="clr-namespace:VsAgentic.UI.Controls;assembly=VsAgentic.UI"
        Title="VsAgentic Desktop"
        Height="750" Width="950"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToSymbolConverter x:Key="StatusToSymbol"/>
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVis"/>

        <!-- User Message Template -->
        <DataTemplate x:Key="UserTemplate" DataType="{x:Type vm:ChatItemViewModel}">
            <Border Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="12,2,12,2">
                <StackPanel>
                    <TextBlock Text="You" FontWeight="SemiBold" Foreground="#569cd6"
                               FontSize="11" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding Content}" Foreground="#d4d4d4"
                               TextWrapping="Wrap" FontSize="13"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Assistant Message Template -->
        <DataTemplate x:Key="AssistantTemplate" DataType="{x:Type vm:ChatItemViewModel}">
            <Border Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="12,2,12,2">
                <StackPanel>
                    <TextBlock Text="Assistant" FontWeight="SemiBold" Foreground="#c586c0"
                               FontSize="11" Margin="0,0,0,2"/>
                    <!-- Streaming: show text as it arrives -->
                    <controls:MarkdownWebView
                        Markdown="{Binding Content}"
                        Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}"
                        MaxRenderHeight="400"/>
                    <!-- Completed: full markdown rendered -->
                    <controls:MarkdownWebView
                        Markdown="{Binding Content}"
                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Thinking Template (collapsible, Claude extension style) -->
        <DataTemplate x:Key="ThinkingTemplate" DataType="{x:Type vm:ChatItemViewModel}">
            <Border Background="#1e1e1e" Margin="12,2,12,2">
                <Expander IsExpanded="{Binding IsExpanded}" Foreground="#808080" FontSize="12">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToSymbol}}"
                                       Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                       FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding ExpanderTitle}" Foreground="#808080"
                                       FontSize="12" FontStyle="Italic" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Expander.Header>
                    <Border Background="#1a1a2e" CornerRadius="4" Padding="10,8" Margin="18,4,0,4">
                        <TextBlock Text="{Binding Content}" Foreground="#6a6a8a"
                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                   TextWrapping="Wrap" FontSize="11"
                                   MaxHeight="200"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Expander>
            </Border>
        </DataTemplate>

        <!-- Tool Step Template -->
        <DataTemplate x:Key="ToolStepTemplate" DataType="{x:Type vm:ChatItemViewModel}">
            <Border Background="#252526" BorderBrush="#3c3c3c" BorderThickness="1"
                    CornerRadius="4" Padding="8,6" Margin="12,2,12,2">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusToSymbol}}"
                                   Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                   FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Foreground="#808080" FontSize="12" VerticalAlignment="Center">
                            <Run Text="["/><Run Text="{Binding ToolName, Mode=OneWay}"/><Run Text="]"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Title}" Foreground="#9cdcfe" FontSize="12"
                                   Margin="6,0,0,0" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <!-- Streaming: collapsible delta content -->
                    <Expander IsExpanded="{Binding IsExpanded}"
                              Header="{Binding ExpanderTitle}"
                              Foreground="#808080" FontSize="11"
                              Margin="18,4,0,0"
                              Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Content}" Foreground="#6a9955"
                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                   TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"/>
                    </Expander>
                    <!-- Tool output body (completed) -->
                    <controls:MarkdownWebView
                        Markdown="{Binding Body}"
                        MaxRenderHeight="120"
                        Margin="18,4,0,0"
                        Visibility="{Binding Body, Converter={StaticResource NotNullToVis}}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <ui:ChatItemTemplateSelector x:Key="ChatItemSelector"
            UserTemplate="{StaticResource UserTemplate}"
            AssistantTemplate="{StaticResource AssistantTemplate}"
            ToolStepTemplate="{StaticResource ToolStepTemplate}"
            ThinkingTemplate="{StaticResource ThinkingTemplate}"/>

        <!-- Button style for dark theme -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007acc"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a8ad4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3c3c3c"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#d4d4d4"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3c3c3c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#333333" Padding="16,10"
                BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Clear" Command="{Binding ClearCommand}"
                            Style="{StaticResource ClearButtonStyle}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VsAgentic Desktop" Foreground="#d4d4d4"
                               FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WorkingDirectory}" Foreground="#808080"
                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Input Area -->
        <Border DockPanel.Dock="Bottom" Background="#252526" Padding="12,10"
                BorderBrush="#3c3c3c" BorderThickness="0,1,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Send"
                        Command="{Binding SendCommand}"
                        Style="{StaticResource SendButtonStyle}"
                        VerticalAlignment="Bottom" Margin="8,0,0,0"/>
                <TextBox x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3c3c3c" Foreground="#d4d4d4"
                         BorderBrush="#555" BorderThickness="1"
                         Padding="10,8" FontSize="13"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="40" MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown"
                         CaretBrush="#d4d4d4"
                         SelectionBrush="#264f78"/>
            </DockPanel>
        </Border>

        <!-- Busy indicator -->
        <Border DockPanel.Dock="Bottom" Background="#1e1e1e" Padding="16,6"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Thinking..." Foreground="#808080" FontSize="12" FontStyle="Italic"/>
        </Border>

        <!-- Chat Messages Area -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#1e1e1e">
            <ItemsControl ItemsSource="{Binding Items}"
                          ItemTemplateSelector="{StaticResource ChatItemSelector}"
                          Padding="0,8"/>
        </ScrollViewer>
    </DockPanel>
</Window>
