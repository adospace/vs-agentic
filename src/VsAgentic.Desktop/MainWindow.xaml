<Window x:Class="VsAgentic.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VsAgentic.UI.Controls;assembly=VsAgentic.UI"
        Title="VsAgentic Desktop"
        Height="750" Width="950"
        Background="#1e1e1e"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SendWhenIdleStyle" TargetType="Button" BasedOn="{StaticResource SendButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopWhenBusyStyle" TargetType="Button" BasedOn="{StaticResource SendButtonStyle}">
            <Setter Property="Background" Value="#c42b2b"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e03535"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Button style for dark theme -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007acc"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a8ad4"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#3c3c3c"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#333333" Padding="16,10"
                BorderBrush="#3c3c3c" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VsAgentic Desktop" Foreground="#d4d4d4"
                               FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WorkingDirectory}" Foreground="#808080"
                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Input Area -->
        <Border DockPanel.Dock="Bottom" Background="#252526" Padding="12,10"
                BorderBrush="#3c3c3c" BorderThickness="0,1,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Right" VerticalAlignment="Bottom" Margin="8,0,0,0">
                    <Button Content="Send"
                            Command="{Binding SendCommand}"
                            Style="{StaticResource SendWhenIdleStyle}"/>
                    <Button Content="&#9632; Stop"
                            ToolTip="Stop processing"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource StopWhenBusyStyle}"/>
                </Grid>
                <TextBox x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Background="#3c3c3c" Foreground="#d4d4d4"
                         BorderBrush="#555" BorderThickness="1"
                         Padding="10,8" FontSize="13"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="40" MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown"
                         CaretBrush="#d4d4d4"
                         SelectionBrush="#264f78"/>
            </DockPanel>
        </Border>

        <!-- Busy indicator -->
        <Border DockPanel.Dock="Bottom" Background="#1e1e1e" Padding="16,6"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Thinking..." Foreground="#808080" FontSize="12" FontStyle="Italic"/>
        </Border>

        <!-- Chat Messages Area - single WebView -->
        <controls:ChatWebView x:Name="ChatWebView" />
    </DockPanel>
</Window>
