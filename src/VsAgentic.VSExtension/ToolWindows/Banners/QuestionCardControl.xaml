<UserControl x:Class="VsAgentic.VSExtension.ToolWindows.Banners.QuestionCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:bvm="clr-namespace:VsAgentic.UI.ViewModels.Banners;assembly=VsAgentic.UI">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/VsAgentic.VSExtension;component/ToolWindows/Banners/BannerStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Inner template for a single QuestionViewModel — bound to the
                 ContentControl in row 2. Hosts the question text, the
                 option list (radio or check, depending on MultiSelect),
                 and the "Other:" free-text row. -->
            <DataTemplate x:Key="QuestionTemplate" DataType="{x:Type bvm:QuestionViewModel}">
                <StackPanel Margin="12,6,12,6">
                    <TextBlock Text="{Binding QuestionText}"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                               Margin="0,2,0,10"
                               TextWrapping="Wrap"/>

                    <!-- Single-select: radios. WPF enforces exclusion via
                         GroupName, which is bound to the question's GUID so
                         each card has its own group. -->
                    <ItemsControl ItemsSource="{Binding Options}"
                                  Margin="8,0,0,4">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MultiSelect}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type bvm:OptionViewModel}">
                                <RadioButton Style="{StaticResource FluentRadioButtonStyle}"
                                             IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                             GroupName="{Binding DataContext.GroupName, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"
                                                   Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                                                   Opacity="0.78"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Multi-select: checkboxes. -->
                    <ItemsControl ItemsSource="{Binding Options}"
                                  Margin="8,0,0,4">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MultiSelect}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type bvm:OptionViewModel}">
                                <CheckBox Style="{StaticResource FluentCheckBoxStyle}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}"
                                                   Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                                                   Opacity="0.78"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- "Other:" row — radio (single-select) or check (multi-
                         select) toggle paired with a free-text TextBox so the
                         user can keep their selection and still type. -->
                    <Grid Margin="8,6,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <RadioButton Grid.Column="0"
                                     IsChecked="{Binding IsOtherSelected, Mode=TwoWay}"
                                     GroupName="{Binding GroupName}"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                            <RadioButton.Style>
                                <Style TargetType="RadioButton" BasedOn="{StaticResource FluentRadioButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MultiSelect}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RadioButton.Style>
                            <TextBlock Text="Other:"
                                       Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                                       VerticalAlignment="Center"/>
                        </RadioButton>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsOtherSelected, Mode=TwoWay}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource FluentCheckBoxStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MultiSelect}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                            <TextBlock Text="Other:"
                                       Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                                       VerticalAlignment="Center"/>
                        </CheckBox>

                        <TextBox Grid.Column="1"
                                 x:Name="OtherTextBox"
                                 Style="{StaticResource BannerInputTextBoxStyle}"
                                 Text="{Binding OtherText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Type your own answer"
                                 MinWidth="200"/>
                    </Grid>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource BannerCardBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: header strip — chevrons + counter + label -->
            <Grid Grid.Row="0" Margin="8,8,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource ChevronButtonStyle}"
                        Command="{Binding GoPrevCommand}"
                        ToolTip="Previous question"
                        Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE76B;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button Grid.Column="1"
                        Style="{StaticResource ChevronButtonStyle}"
                        Command="{Binding GoNextCommand}"
                        ToolTip="Next question"
                        Visibility="{Binding ShowNavigation, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="&#xE76C;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <TextBlock Grid.Column="2"
                           Text="{Binding CounterText}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource {x:Static vs:VsBrushes.CommandBarTextInactiveKey}}"/>

                <TextBlock Grid.Column="3"
                           Text="{Binding HeaderLabel}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="12"
                           Opacity="0.85"
                           Foreground="{DynamicResource {x:Static vs:VsBrushes.ToolWindowTextKey}}"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <!-- Row 1: separator under the header -->
            <Border Grid.Row="1"
                    Height="1"
                    Margin="0,4,0,0"
                    Opacity="0.5"
                    Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBorderKey}}"/>

            <!-- Row 2: current question host -->
            <ContentControl Grid.Row="2"
                            Content="{Binding CurrentQuestion}"
                            ContentTemplate="{StaticResource QuestionTemplate}"
                            Margin="0,4,0,0"/>

            <!-- Row 3: submit -->
            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="8,4,12,10">
                <Button Content="{Binding SubmitLabel}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SubmitCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
