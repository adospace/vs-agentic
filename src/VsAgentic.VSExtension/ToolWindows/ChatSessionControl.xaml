<UserControl x:Class="VsAgentic.VSExtension.ToolWindows.ChatSessionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:controls="clr-namespace:VsAgentic.UI.Controls;assembly=VsAgentic.UI" >

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="SendWhenIdleStyle" TargetType="Button"
               BasedOn="{StaticResource {x:Static vs:VsResourceKeys.ButtonStyleKey}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopWhenBusyStyle" TargetType="Button"
               BasedOn="{StaticResource {x:Static vs:VsResourceKeys.ButtonStyleKey}}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource {x:Static vs:VsBrushes.CommandBarGradientBeginKey}}"
                Padding="16,8"
                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="VsAgentic Chat"
                               Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding WorkingDirectory}"
                               Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Input Area -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static vs:VsBrushes.CommandBarGradientBeginKey}}"
                Padding="12,8"
                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.CommandBarBorderKey}}"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Right" VerticalAlignment="Bottom" Margin="8,0,0,0">
                    <Button Content="Send"
                            Command="{Binding SendCommand}"
                            Style="{StaticResource SendWhenIdleStyle}"
                            Padding="16,6"/>
                    <Button Content="&#9632; Stop"
                            ToolTip="Stop processing"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource StopWhenBusyStyle}"
                            Padding="16,6"/>
                </Grid>
                <TextBox x:Name="InputTextBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource {x:Static vs:VsResourceKeys.TextBoxStyleKey}}"
                         Padding="8,6" FontSize="13"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="36" MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="InputTextBox_KeyDown"/>
            </DockPanel>
        </Border>

        <!-- Busy indicator -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
                Padding="16,4"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Thinking..."
                       Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                       FontSize="12" FontStyle="Italic"/>
        </Border>

        <!-- Chat Messages Area - single WebView -->
        <controls:ChatWebView x:Name="ChatWebView" />
    </DockPanel>
</UserControl>
