<UserControl x:Class="VsAgentic.VSExtension.ToolWindows.ChatSessionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vs="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             xmlns:controls="clr-namespace:VsAgentic.UI.Controls;assembly=VsAgentic.UI"
             xmlns:bvm="clr-namespace:VsAgentic.UI.ViewModels.Banners;assembly=VsAgentic.UI"
             xmlns:bv="clr-namespace:VsAgentic.VSExtension.ToolWindows.Banners" >

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Banner DataTemplates: ContentControl below picks the right view by VM type. -->
        <DataTemplate DataType="{x:Type bvm:PermissionBannerViewModel}">
            <bv:PermissionBannerControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type bvm:LoginBannerViewModel}">
            <bv:LoginBannerControl/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type bvm:QuestionCardViewModel}">
            <bv:QuestionCardControl/>
        </DataTemplate>

        <!-- Borderless icon button used inside the input status bar -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseDownBackgroundGradientKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SendButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ListBoxItem template used in the @-mention popup -->
        <Style x:Key="MentionItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                CornerRadius="3"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource {x:Static vs:VsBrushes.CommandBarSelectedKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel x:Name="RootPanel"
               Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}">

        <!-- Input Area -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
                Padding="6,2,6,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Resize grip: thin transparent strip the user can drag up/down -->
                <Border x:Name="ResizeGrip"
                        Grid.Row="0"
                        Height="6"
                        Background="Transparent"
                        Cursor="SizeNS"
                        MouseLeftButtonDown="ResizeGrip_MouseLeftButtonDown"
                        MouseMove="ResizeGrip_MouseMove"
                        MouseLeftButtonUp="ResizeGrip_MouseLeftButtonUp"
                        ToolTip="Drag to resize input"/>

                <!-- Rounded input container holding the textbox + status bar -->
                <Border Grid.Row="1"
                        CornerRadius="4"
                        Background="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBackgroundKey}}"
                        BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
                        BorderThickness="1"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Text input + placeholder overlay -->
                        <Grid Grid.Row="0">
                            <TextBox x:Name="InputTextBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"
                                     CaretBrush="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"
                                     BorderThickness="0"
                                     Padding="8,6"
                                     FontSize="13"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="36"
                                     MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     KeyDown="InputTextBox_KeyDown"
                                     PreviewKeyDown="InputTextBox_PreviewKeyDown"
                                     TextChanged="InputTextBox_TextChanged"
                                     SelectionChanged="InputTextBox_SelectionChanged"
                                     LostKeyboardFocus="InputTextBox_LostKeyboardFocus"/>

                            <!-- @-mention popup: anchored above the input box, holds a filtered file/folder list -->
                            <Popup x:Name="MentionPopup"
                                   PlacementTarget="{Binding ElementName=InputTextBox}"
                                   Placement="Top"
                                   StaysOpen="True"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Focusable="False">
                                <Border Background="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBackgroundKey}}"
                                        BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="260"
                                        MaxWidth="520"
                                        SnapsToDevicePixels="True">
                                    <ListBox x:Name="MentionList"
                                             MaxHeight="220"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Focusable="False"
                                             ItemContainerStyle="{StaticResource MentionItemStyle}"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             PreviewMouseLeftButtonDown="MentionList_PreviewMouseLeftButtonDown">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <imaging:CrispImage Grid.Column="0"
                                                                        Width="14" Height="14"
                                                                        VerticalAlignment="Center"
                                                                        Margin="0,0,6,0"
                                                                        Moniker="{Binding Moniker}"/>
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               Text="{Binding RelativePath}"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                            <TextBlock Text="Type your message, CTRL+Enter to send, @ to enter"
                                       Margin="11,6,0,0"
                                       VerticalAlignment="Top"
                                       IsHitTestVisible="False"
                                       FontSize="13"
                                       Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Status bar (separated from textbox by a top line) -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource {x:Static vs:VsBrushes.ComboBoxBorderKey}}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- @-mention attach button: opens the file/folder picker popup -->
                                <Button Grid.Column="0"
                                        x:Name="AtMentionButton"
                                        Style="{StaticResource IconButtonStyle}"
                                        Click="AtMentionButton_Click"
                                        ToolTip="Insert file or folder reference (@)">
                                    <TextBlock Text="@"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource {x:Static vs:VsBrushes.WindowTextKey}}"/>
                                </Button>

                                <!-- Status info area (reserved for future) -->
                                <TextBlock Grid.Column="1"
                                           x:Name="StatusInfoText"
                                           VerticalAlignment="Center"
                                           Margin="10,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Send / Stop buttons -->
                                <Grid Grid.Column="2" Margin="2">
                                    <Button Style="{StaticResource SendButtonStyle}"
                                            Command="{Binding SendCommand}"
                                            ToolTip="Send (Ctrl+Enter)">
                                        <imaging:CrispImage Width="16" Height="16"
                                                            Moniker="{x:Static catalog:KnownMonikers.Send}"/>
                                    </Button>
                                    <Button Style="{StaticResource StopButtonStyle}"
                                            Command="{Binding StopCommand}"
                                            ToolTip="Stop processing">
                                        <imaging:CrispImage Width="16" Height="16"
                                                            Moniker="{x:Static catalog:KnownMonikers.Stop}"/>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Busy indicator -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static vs:VsBrushes.ToolWindowBackgroundKey}}"
                Padding="16,4"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Thinking..."
                       Foreground="{DynamicResource {x:Static vs:VsBrushes.GrayTextKey}}"
                       FontSize="12" FontStyle="Italic"/>
        </Border>

        <!-- Banner host: permission / question / login banner. The DataTemplates
             above pick the matching UserControl by VM type. The host collapses
             when ActiveBanner is null so it consumes no space when idle. -->
        <ContentControl DockPanel.Dock="Bottom"
                        x:Name="BannerHost"
                        Content="{Binding ActiveBanner}"
                        Focusable="False">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- Chat Messages Area - single WebView -->
        <controls:ChatWebView x:Name="ChatWebView" />
    </DockPanel>
</UserControl>
